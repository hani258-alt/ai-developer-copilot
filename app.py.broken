<script>
// 隐藏Streamlit原生组件
document.querySelectorAll('.stTextArea, .stTextInput, .stButton > button, [data-testid="stFileUploader"], [data-testid="stRadio"]').forEach(el => {
    el.style.display = 'none';
});
</script>
""", unsafe_allow_html=True)
