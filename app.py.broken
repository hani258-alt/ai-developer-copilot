    st.markdown("""
    <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr);">
        <div class="stat-card">
            <div class="stat-card-label">支持格式</div>
            <div class="stat-card-value">PDF / MD / TXT</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">笔记生成</div>
            <div class="stat-card-value accent">AI</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">导出格式</div>
            <div class="stat-card-value">Markdown</div>
        </div>
    </div>
    
    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <span class="card-icon">📝</span>
                上传教程文档
            </div>
        </div>
        
        <div class="upload-zone" onclick="document.getElementById('noteInput').click()" style="margin-bottom: 20px;">
            <div class="upload-zone-icon">📚</div>
            <div class="upload-zone-title">拖拽文件或点击上传</div>
            <div class="upload-zone-desc">上传教程文档，AI将自动生成学习笔记</div>
            <div class="upload-zone-formats">支持 PDF、Markdown、TXT 格式</div>
        </div>
        <input type="file" id="noteInput" class="hidden-file-input" accept=".pdf,.md,.txt">
        
        <button class="btn btn-primary" style="width: 100%;">生成学习笔记</button>
    </div>
    
    <!-- 生成的笔记 -->
    <div class="card" style="margin-top: 24px;">
        <div class="card-header">
            <div class="card-title">
                <span class="card-icon">📄</span>
                学习笔记
            </div>
            <button class="btn btn-secondary">📥 导出</button>
        </div>
        <div class="empty-state" style="padding: 40px;">
            <div class="empty-state-icon">✏️</div>
            <div class="empty-state-title">暂无笔记</div>
            <div class="empty-state-desc">上传教程文档后，AI将自动生成结构化的学习笔记</div>
        </div>
    </div>
    """, unsafe_allow_html=True)

