# 页面切换JavaScript
st.markdown("""
<script>
const tabNames = {
    'chat': 'AI Copilot',
    'knowledge': '知识库',
    'code': '代码分析',
    'error': '报错诊断',
    'notes': '学习笔记'
};

// 监听来自iframe的消息
window.addEventListener('message', (event) => {
    const data = event.data;
    if (data.type === 'switch_tab') {
        window.location.hash = data.tab;
        document.getElementById('pageTitle').textContent = tabNames[data.tab] || 'AI Copilot';
    }
    if (data.type === 'new_chat') {
        window.location.reload();
    }
});

// 根据hash初始化
if (window.location.hash) {
    const tab = window.location.hash.slice(1);
    document.getElementById('pageTitle').textContent = tabNames[tab] || 'AI Copilot';
}
</script>
""", unsafe_allow_html=True)

# 底部脚本处理
